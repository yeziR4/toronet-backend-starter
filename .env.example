# Toronet Backend Starter - Environment Configuration
# Copy this file to .env and fill in your values.

# Network: "testnet" or "mainnet"
TORONET_NETWORK=testnet

# Toronet RPC endpoint (optional, defaults to testnet/mainnet public RPC)
# TORONET_RPC_URL=http://testnet.toronet.org

# Server configuration
PORT=3000
HOST=0.0.0.0

# Logging level: "debug" | "info" | "warn" | "error"
LOG_LEVEL=info

# Wallet configuration (optional - used for stateful operations)
# Leave empty for query-only mode
# WALLET_PRIVATE_KEY=
# WALLET_PASSWORD=
