# Toronet Backend Starter - Environment Configuration
# Copy this file to .env and fill in your values.

# Network: "testnet" or "mainnet"
TORONET_NETWORK=testnet

# ⚠️ SDK Base URL override
# The torosdk v0.2.0 default URLs are:
#   mainnet → https://api.toronet.org  (returns chain 7777 "testnet", balance=0 for funded wallets!)
#   testnet → http://testnet.toronet.org (returns 404)
# The correct testnet API with real on-chain data is:
#   https://testnet.toronet.org/api  (chain 54321, real balances)
# Uncomment and set the correct URL:
# TORONET_BASE_URL=https://testnet.toronet.org/api

# Optional: Override ConnectW and Deployer URLs (SDK defaults are usually correct)
# TORONET_CONNECT_W_URL=https://payments.connectw.com
# TORONET_DEPLOYER_URL=https://deployer.toronet.org/api/testnet

# Server configuration
PORT=3000
HOST=0.0.0.0

# Logging level: "debug" | "info" | "warn" | "error"
LOG_LEVEL=info

# Wallet credentials (optional, required only for custodial TORO transfer)
# WALLET_PRIVATE_KEY=0x...
# WALLET_PASSWORD=your_password

# Live proof script gate (set to 1 to allow --transfer flag to execute)
# LIVE_PROOF_TRANSFER=1
