# Toronet Backend Starter - Environment Configuration
# Copy this file to .env and fill in your values.

# Network: "testnet" or "mainnet"
TORONET_NETWORK=testnet

# ⚠️ SDK Base URL override
# The torosdk v0.2.0 default testnet URL (http://testnet.toronet.org) is broken
# and returns 404 for all paths. The working endpoint is https://api.toronet.org.
# Uncomment the line below to override the SDK default:
# TORONET_BASE_URL=https://api.toronet.org

# Optional: Override ConnectW and Deployer URLs (SDK defaults are usually correct)
# TORONET_CONNECT_W_URL=https://payments.connectw.com
# TORONET_DEPLOYER_URL=https://deployer.toronet.org/api/testnet

# Server configuration
PORT=3000
HOST=0.0.0.0

# Logging level: "debug" | "info" | "warn" | "error"
LOG_LEVEL=info
